# OpenRouter credentials
OPENROUTER_API_KEY=sk-or-REPLACE_ME # Alternatively use .streamlit/secrets.toml to store this
OPENROUTER_MODEL=openai/gpt-oss-120b
# Optional (helps with OpenRouter rankings/allow-list)
OPENROUTER_HTTP_REFERER=http://localhost:8501
OPENROUTER_SITE_TITLE=Personal Website Assistant

# Content + safety controls
# Content scope is fixed to the repository's content/ directory.
SAFETY_MODE=moderate
MAX_USER_CHARS=2000
MAX_ARTICLE_CONTEXT_CHARS=12000
# Comma separated denylist terms, e.g. "malware,exploit"
BLOCKED_TERMS=

# Streamlit
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_PORT=8501
